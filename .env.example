# ── フロントエンド (apps/web) ───────────────────────────────
# データ取得元: bff = FastAPI経由 / mock = フロント単独(API不要・デモ安全網)
NEXT_PUBLIC_DATA_SOURCE=bff
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── バックエンド BFF (apps/api) ─────────────────────────────
# リポジトリ実装: mock = インメモリ(MVP) / firestore = 実Firestore(将来)
DATA_SOURCE=mock
# エージェントのLLM: mock = 決定的キャンド(MVP) / vertex = Vertex Gemini(将来)
PUBLISHR_LLM=mock
# プロンプトのfew-shot注入(packages/prompts/README §4): on = ✅良い例を1件差し込む(既定) / off = devでコスト節約。
# ※生成系(owner/author/persona/cover/step1)のみ効く。採点系(leader/editor/judge)は常時ON固定。
PROMPT_FEWSHOT=on

# ── GCP (将来のデプロイ用・MVPでは未使用) ───────────────────
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_REGION=asia-northeast1
# GCS_BUCKET=
