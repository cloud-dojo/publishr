# ── フロントエンド (apps/web) ───────────────────────────────
# データ取得元: bff = FastAPI経由 / mock = フロント単独(API不要・デモ安全網)
NEXT_PUBLIC_DATA_SOURCE=bff
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── バックエンド BFF (apps/api) ─────────────────────────────
# リポジトリ実装: mock = インメモリ(MVP) / firestore = 実Firestore(将来)
DATA_SOURCE=mock
# エージェントのLLM: mock = 決定的キャンド(MVP) / vertex = Vertex Gemini(将来)
PUBLISHR_LLM=mock
# プロンプトのfew-shot注入(packages/prompts/README §4): on = ✅良い例を1件差し込む(既定) / off = devでコスト節約。
# ※生成系(owner/author/persona/cover/step1)のみ効く。採点系(leader/editor/judge)は常時ON固定。
PROMPT_FEWSHOT=on

# 実LLM実行プロファイル: dev = 小さく安全に検証 / prod = デモ・録画時のみ明示。
PUBLISHR_RUN_PROFILE=dev
PUBLISHR_MAX_ITERATIONS=3
# dev is intentionally smaller than the product contract.
# prod default is 4 books/run = 3 runs/week x 4 books = 12 weekly books.
PUBLISHR_MAX_BOOKS_PER_RUN=2
PUBLISHR_BODY_PAGES_MIN=3
PUBLISHR_MAX_BODY_PAGES=5
PUBLISHR_EDITOR_ROUNDS=1
PUBLISHR_TIMEOUT_SECONDS=45
PUBLISHR_MAX_ESTIMATED_COST_JPY=100
ENABLE_IMAGEN=false

# ── GCP (将来のデプロイ用・MVPでは未使用) ───────────────────
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_REGION=asia-northeast1
# GCS_BUCKET=
