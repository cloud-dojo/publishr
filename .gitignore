# Node / Next.js
node_modules/
.next/
out/
dist/
*.tsbuildinfo
.turbo/
# ルートのpackage-lock.jsonはGit管理しない
# (apps/web/package-lock.jsonは残す - Firebase App Hosting が使用)
# Turbopackが複数lockfileを検出するとworkspace rootを誤検知するため
/package-lock.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
.python-version

# Env / secrets
.env
.env.local
.env.*.local
*.key.json
service-account*.json
local-cost-guard/

# Docs 共有方針: design/ui/infra/planning + README を共有。ピッチ/demo台本/WBS は Drive 管理（repo外）
.github/CODEOWNERS
docs/*
!docs/README.md
!docs/design/
!docs/ui/
!docs/infra/
!docs/planning/
# 生成された設計図(html/pdf)は非追跡
docs/**/*.html
docs/**/*.pdf
.cursor/

# OS / editor
.DS_Store
*:Zone.Identifier
.idea/
.vscode/
.claude/

# Build / coverage
coverage/
htmlcov/
.coverage

# Claude Code 内部ファイル
.agents/
skills-lock.json
